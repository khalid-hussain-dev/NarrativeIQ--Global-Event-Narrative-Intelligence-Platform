# NarrativeIQ local configuration
#
# 1. Copy this file to .env
# 2. Replace the password/database details below
# 3. Run: powershell -ExecutionPolicy Bypass -File scripts/check_postgres.ps1

NARRATIVEIQ_DATABASE_URL=postgresql://postgres:your_password@localhost:5432/narrativeiq
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Sprint 3 LLM Enrichment
DEEPSEEK_API_KEY=your_deepseek_api_key

# Sprint 4 Auth / Roles (API Key Guard for admin operations)
NARRATIVEIQ_ADMIN_KEY=your_admin_key_here
