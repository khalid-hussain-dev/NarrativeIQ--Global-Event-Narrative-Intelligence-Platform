# ── Secrets & environment ──────────────────────────────────────────────────
.env
*.env.local
*.env.production

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
*.so
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.cover

# ── Node / Next.js ─────────────────────────────────────────────────────────
node_modules/
.next/
.npm-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
out/

# ── Large generated / warehouse data ───────────────────────────────────────
# Keep mart JSONs (they power the app on first boot)
# Exclude raw warehouse CSVs — regenerated by ETL
datasets/warehouse/fact_content.csv
datasets/imports/
datasets/enriched/
datasets/custom/

# ── Reports (generated on demand) ──────────────────────────────────────────
reports/generated/*.pdf
reports/generated/*.html

# ── Logs ───────────────────────────────────────────────────────────────────
logs/*.jsonl
logs/*.log

# ── Temp / system ──────────────────────────────────────────────────────────
.tmp/
*.tmp
*.bak
*.swp
*.DS_Store
Thumbs.db
desktop.ini

# ── IDE / editors ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Windows ────────────────────────────────────────────────────────────────
$RECYCLE.BIN/
ehthumbs.db
